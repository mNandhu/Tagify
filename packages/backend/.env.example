MONGO_URI=mongodb://localhost:27017
# Mongo tuning (optional; adjust for production/high concurrency)
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=0
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
AI_TAGGING_URL=http://localhost:9000/infer

# Thumbnail storage: local filesystem root for generated WebP thumbnails.
# Defaults to ./data/thumbs. Keep it on a persistent volume, outside library trees.
THUMB_ROOT=./data/thumbs

# Scanner tuning
SCANNER_MAX_WORKERS=0
SCAN_PROGRESS_UPDATE_MS=500
THUMB_MAX_SIZE=1080  # Max pixels for longest edge of generated thumbnails

# Ops / safety
LOG_SLOW_REQUESTS_MS=1000
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RESCAN_PER_MINUTE=1
