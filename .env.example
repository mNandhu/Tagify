# Tagify Docker Compose Environment Configuration
# Copy this file to .env and adjust values as needed

# MongoDB Configuration
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password

# Thumbnail Configuration
# Local filesystem root for generated WebP thumbnails. In Docker this is a
# mounted volume (/data/thumbs); for local dev it defaults to ./data/thumbs.
THUMB_ROOT=/data/thumbs
THUMB_MAX_SIZE=1080

# Scanner Configuration
# 0 = auto detect CPU cores
SCANNER_MAX_WORKERS=0

# AI Tagging (optional)
# Leave empty to disable AI tagging
AI_TAGGING_URL=